<Window x:Class="RiftSentry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RiftSentry"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="True">
    <Border x:Name="RootBorder"
            Padding="6"
            CornerRadius="6"
            Background="#660D1117"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">
        <StackPanel MinWidth="120">
            <Border Height="6"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"/>
            <ItemsControl ItemsSource="{Binding Enemies}"
                          Visibility="{Binding IsInGame, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,4"
                                Padding="4"
                                CornerRadius="4"
                                Background="#0DFFFFFF">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       Width="28"
                                       Height="28"
                                       RenderOptions.BitmapScalingMode="Fant"
                                       Source="{Binding PortraitPath, Converter={StaticResource PathToImage}}">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <StackPanel Grid.Column="1"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Button Width="34"
                                            Height="34"
                                            Padding="0"
                                            Focusable="False"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding SpellOne.ToggleCommand}">
                                        <Grid Width="30" Height="30">
                                            <Image RenderOptions.BitmapScalingMode="Fant"
                                                   Source="{Binding SpellOne.IconPath, Converter={StaticResource PathToImage}}"/>
                                            <Border Background="#8F000000"
                                                    CornerRadius="3"
                                                    Visibility="{Binding SpellOne.IsOnCooldown, Converter={StaticResource BoolToVis}}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="10"
                                                           Text="{Binding SpellOne.RemainingText}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                    <Button Width="34"
                                            Height="34"
                                            Margin="4,0,0,0"
                                            Padding="0"
                                            Focusable="False"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding SpellTwo.ToggleCommand}">
                                        <Grid Width="30" Height="30">
                                            <Image RenderOptions.BitmapScalingMode="Fant"
                                                   Source="{Binding SpellTwo.IconPath, Converter={StaticResource PathToImage}}"/>
                                            <Border Background="#8F000000"
                                                    CornerRadius="3"
                                                    Visibility="{Binding SpellTwo.IsOnCooldown, Converter={StaticResource BoolToVis}}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="10"
                                                           Text="{Binding SpellTwo.RemainingText}"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Width="22"
                                        Height="22"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Padding="0"
                                        Focusable="False"
                                        FontWeight="Bold"
                                        FontSize="10"
                                        ToolTip="{Binding CosmicButtonTooltip}"
                                        Content="C"
                                        Command="{Binding ToggleCosmicCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#21262D"/>
                                            <Setter Property="Foreground" Value="#8B949E"/>
                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ManualCosmicInsightOverride}" Value="True"/>
                                                        <Condition Binding="{Binding HasCosmicInsightFromApi}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#9A6700"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding HasCosmicInsightFromApi}" Value="True">
                                                    <Setter Property="Background" Value="#238636"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
